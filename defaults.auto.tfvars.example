project_name      = "nomad-enterprise"
nomad_license     = "your-nomad-enterprise-license-here"
ec2_key_pair_name = "my-key-pair"

route53_zone = {
  zone_id = "Z0123456789ABCDEFGHIJ"
  name    = "example.com"
}

ec2_ami = {
  id   = "ami-0abcdef1234567890"
  name = "ubuntu-noble-24.04-amd64-server"
}

consul_security_group = {
  id = "sg-0abcdef1234567890"
}

consul_auto_join_ec2_tag = {
  key   = "consul-cluster"
  value = "auto-join"
}

nomad_server_service_name = "nomad-server"
nomad_client_service_name = "nomad-client"

vault_fqdn                 = "vault.example.com"
vault_ca_cert              = "-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
iam_server_id_header_value = "vault.example.com"
